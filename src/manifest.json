{
  "manifest_version": 3,
  "name": "소마 멘토링 캘린더 개선",
  "icons": {
    "16": "icon/16.png",
    "32": "icon/32.png",
    "48": "icon/48.png",
    "128": "icon/128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.swmaestro.ai/*",
    "https://*.swmaestro.org/*",
    "https://asm-schedule-alarm.pa6764.workers.dev/*"
  ],
  "background": {
    "service_worker": "src/background.ts"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.swmaestro.ai/*"
      ],
      "js": ["src/calendar-export.ts", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.swmaestro.org/busan/sw/mypage/userAnswer/history.do*",
        "*://*.swmaestro.ai/busan/sw/mypage/userAnswer/history.do*",
        "*://*.swmaestro.org/sw/mypage/userAnswer/history.do*",
        "*://*.swmaestro.ai/sw/mypage/userAnswer/history.do*",
        "*://*.swmaestro.org/busan/sw/mypage/mentoLec/view.do*",
        "*://*.swmaestro.ai/busan/sw/mypage/mentoLec/view.do*",
        "*://*.swmaestro.org/sw/mypage/mentoLec/view.do*",
        "*://*.swmaestro.ai/sw/mypage/mentoLec/view.do*"
      ],
      "js": ["src/calendar-export.ts", "src/alarm-client.js", "src/schedule-manager.js"],
      "css": ["src/schedule-manager.css", "src/alarm-client.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icon/16.png",
      "32": "icon/32.png"
    },
    "default_title": "소마 멘토링 캘린더 개선"
  }
}
